# =============================================================================
# AuroraForge – Environment Variables
# Copy to .env and fill in real values. Never commit .env to source control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=change_me_strong_password_here

# --- Redis ---
REDIS_PASSWORD=change_me_strong_redis_password

# --- MinIO (local S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_minio_password

# --- Vault (local dev only – use Vault Enterprise or cloud KMS in production) ---
VAULT_DEV_ROOT_TOKEN=auroraforge-dev

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ---------------------------------------------------------------------------
# AWS (used by Terraform and cloud deployments; NOT needed for local Docker dev)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_EKS_CLUSTER_NAME=auroraforge-eks
AWS_RDS_DB_PASSWORD=change_me_rds_password
AWS_KMS_KEY_ALIAS=alias/auroraforge-cmk

# TF remote state
TF_STATE_BUCKET=auroraforge-tfstate-123456789012
TF_STATE_DYNAMODB_TABLE=auroraforge-tf-locks

# ---------------------------------------------------------------------------
# Azure (used by Terraform and cloud deployments; NOT needed for local Docker dev)
# ---------------------------------------------------------------------------
ARM_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
ARM_TENANT_ID=00000000-0000-0000-0000-000000000001
ARM_CLIENT_ID=00000000-0000-0000-0000-000000000002
ARM_CLIENT_SECRET=change_me_azure_sp_secret
AZURE_RESOURCE_GROUP=auroraforge-rg
AZURE_LOCATION=eastus
AZURE_AKS_CLUSTER_NAME=auroraforge-aks
AZURE_COSMOS_DB_NAME=auroraforge-cosmos
AZURE_KEY_VAULT_NAME=auroraforge-kv

# TF remote state (Azure Blob)
ARM_ACCESS_KEY=change_me_storage_account_access_key

# ---------------------------------------------------------------------------
# Application (Spring Boot services – set in Kubernetes secrets for cloud)
# ---------------------------------------------------------------------------
APP_ENCRYPTION_KEY_VERSION=1
APP_KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9093,kafka-3:9094
APP_SCHEMA_REGISTRY_URL=http://schema-registry:8081
APP_REDIS_URL=redis://redis:6379
APP_OTEL_EXPORTER_ENDPOINT=http://otel-collector:4317
