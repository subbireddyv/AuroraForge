# Copy to terraform.tfvars and fill in real values.
# This file is safe to commit; terraform.tfvars is gitignored.

aws_region           = "us-east-1"
aws_secondary_region = "us-west-2"
aws_account_id       = "123456789012"
environment          = "prod"
project_name         = "auroraforge"

vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b", "us-east-1c"]
private_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
public_subnet_cidrs  = ["10.0.101.0/24", "10.0.102.0/24", "10.0.103.0/24"]

eks_cluster_version         = "1.29"
eks_node_instance_types     = ["m6i.xlarge", "m6a.xlarge"]
eks_node_group_min_size     = 2
eks_node_group_max_size     = 10
eks_node_group_desired_size = 3

rds_instance_class           = "db.r6g.xlarge"
rds_engine_version           = "16.1"
rds_allocated_storage_gb     = 100
rds_max_allocated_storage_gb = 1000
rds_db_name                  = "auroraforge"
rds_master_username          = "auroraforge_admin"
rds_backup_retention_days    = 30

s3_bucket_suffix = "prod-abc123"  # Must be globally unique

kms_key_deletion_window_days = 30
kms_key_rotation_enabled     = true
